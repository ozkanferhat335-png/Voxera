# ============================================================
# Voxera Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# JWT
JWT_SECRET_KEY=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS

# Database
POSTGRES_DB=voxera
POSTGRES_USER=voxera
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# RabbitMQ
RABBITMQ_DEFAULT_USER=voxera
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBITMQ_PASSWORD

# FreeSWITCH
FREESWITCH_ESL_PASSWORD=CHANGE_ME_ESL_PASSWORD
SIP_TRUNK_USER=your_sip_trunk_user
SIP_TRUNK_PASS=your_sip_trunk_password
SIP_TRUNK_HOST=sip.yourprovider.com

# AI (OpenAI)
OPENAI_API_KEY=sk-...

# Domain
DOMAIN=voxera.io
API_DOMAIN=api.voxera.io
APP_DOMAIN=app.voxera.io

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@voxera.io
SMTP_PASS=CHANGE_ME
