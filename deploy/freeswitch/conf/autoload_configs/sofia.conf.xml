<?xml version="1.0" encoding="utf-8"?>
<!--
  Voxera FreeSWITCH Sofia SIP Configuration
  Handles SIP registration, WebRTC, and trunk connections
-->
<configuration name="sofia.conf" description="Sofia SIP">
  <global_settings>
    <param name="log-level" value="0"/>
    <param name="auto-restart" value="false"/>
    <param name="debug-presence" value="0"/>
  </global_settings>

  <profiles>
    <!-- ============================================================ -->
    <!-- Internal SIP Profile (UDP/TCP for softphones)               -->
    <!-- ============================================================ -->
    <profile name="internal">
      <gateways>
        <!-- SIP Trunk Gateway -->
        <gateway name="voxera_trunk">
          <param name="username" value="${sip_trunk_user}"/>
          <param name="password" value="${sip_trunk_pass}"/>
          <param name="proxy" value="${sip_trunk_host}"/>
          <param name="register" value="true"/>
          <param name="caller-id-in-from" value="false"/>
          <param name="contact-params" value="tport=tcp"/>
          <param name="ping" value="25"/>
        </gateway>
      </gateways>

      <settings>
        <param name="debug" value="0"/>
        <param name="sip-trace" value="no"/>
        <param name="sip-capture" value="no"/>
        <param name="rfc2833-pt" value="101"/>
        <param name="sip-port" value="5060"/>
        <param name="dialplan" value="XML"/>
        <param name="context" value="default"/>
        <param name="dtmf-duration" value="2000"/>
        <param name="inbound-codec-prefs" value="PCMU,PCMA,G729,opus"/>
        <param name="outbound-codec-prefs" value="PCMU,PCMA,G729,opus"/>
        <param name="rtp-timer-name" value="soft"/>
        <param name="local-network-acl" value="localnet.auto"/>
        <param name="manage-presence" value="true"/>
        <param name="presence-hosts" value="${domain_name}"/>
        <param name="inbound-codec-negotiation" value="generous"/>
        <param name="nonce-ttl" value="60"/>
        <param name="auth-calls" value="true"/>
        <param name="inbound-late-negotiation" value="true"/>
        <param name="inbound-zrtp-passthru" value="true"/>
        <param name="rtp-ip" value="auto"/>
        <param name="sip-ip" value="auto"/>
        <param name="ext-rtp-ip" value="auto-nat"/>
        <param name="ext-sip-ip" value="auto-nat"/>
        <param name="rtp-timeout-sec" value="300"/>
        <param name="rtp-hold-timeout-sec" value="1800"/>
        <param name="enable-3pcc" value="true"/>
        <param name="tls" value="false"/>
        <param name="tls-sip-port" value="5061"/>
        <param name="tls-cert-dir" value="/etc/freeswitch/tls"/>
        <param name="record-path" value="/var/recordings"/>
        <param name="record-template" value="${caller_id_number}.${target_domain}.${strftime(%Y-%m-%d-%H-%M-%S)}.wav"/>
      </settings>
    </profile>

    <!-- ============================================================ -->
    <!-- WebRTC Profile (WSS for browser clients)                    -->
    <!-- ============================================================ -->
    <profile name="webrtc">
      <settings>
        <param name="debug" value="0"/>
        <param name="sip-port" value="7443"/>
        <param name="dialplan" value="XML"/>
        <param name="context" value="default"/>
        <param name="rfc2833-pt" value="101"/>
        <param name="inbound-codec-prefs" value="opus,PCMU,PCMA"/>
        <param name="outbound-codec-prefs" value="opus,PCMU,PCMA"/>
        <param name="rtp-ip" value="auto"/>
        <param name="sip-ip" value="auto"/>
        <param name="ext-rtp-ip" value="auto-nat"/>
        <param name="ext-sip-ip" value="auto-nat"/>
        <param name="manage-presence" value="true"/>
        <param name="auth-calls" value="true"/>
        <param name="inbound-late-negotiation" value="true"/>
        <param name="inbound-zrtp-passthru" value="true"/>
        <!-- WebSocket/WebRTC settings -->
        <param name="ws-binding" value=":5066"/>
        <param name="wss-binding" value=":7443"/>
        <param name="tls-cert-dir" value="/etc/freeswitch/tls"/>
        <param name="tls-version" value="tlsv1.2,tlsv1.3"/>
        <!-- DTLS for WebRTC -->
        <param name="dtls-enable" value="true"/>
        <param name="dtls-cert-dir" value="/etc/freeswitch/tls"/>
        <param name="rtcp-mux" value="true"/>
        <param name="enable-3pcc" value="true"/>
      </settings>
    </profile>

  </profiles>
</configuration>
