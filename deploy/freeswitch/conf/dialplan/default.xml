<?xml version="1.0" encoding="utf-8"?>
<!--
  Voxera FreeSWITCH Dialplan
  Handles call routing for all extensions
-->
<include>
  <context name="default">

    <!-- ============================================================ -->
    <!-- Internal Extension Calls (100-999)                           -->
    <!-- ============================================================ -->
    <extension name="internal_extensions">
      <condition field="destination_number" expression="^([1-9][0-9]{2,4})$">
        <action application="set" data="call_timeout=30"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="continue_on_fail=true"/>
        <!-- Start recording if extension has record_calls enabled -->
        <action application="set" data="RECORD_STEREO=true"/>
        <action application="set" data="recording_follow_transfer=true"/>
        <!-- Bridge to destination -->
        <action application="bridge" data="sofia/internal/$1@${domain_name}"/>
        <!-- If no answer, go to voicemail -->
        <action application="answer"/>
        <action application="voicemail" data="default ${domain_name} $1"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- IVR Entry Points (8000-8999)                                 -->
    <!-- ============================================================ -->
    <extension name="ivr_menus">
      <condition field="destination_number" expression="^(8[0-9]{3})$">
        <action application="answer"/>
        <action application="sleep" data="1000"/>
        <action application="ivr" data="$1"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- Call Queues (9000-9999)                                      -->
    <!-- ============================================================ -->
    <extension name="call_queues">
      <condition field="destination_number" expression="^(9[0-9]{3})$">
        <action application="answer"/>
        <action application="set" data="queue_name=$1"/>
        <action application="callcenter" data="$1@default"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- Voicemail Direct Access (*98)                                -->
    <!-- ============================================================ -->
    <extension name="voicemail_check">
      <condition field="destination_number" expression="^\*98$">
        <action application="answer"/>
        <action application="voicemail" data="check default ${domain_name} ${caller_id_number}"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- Call Park (*5 + slot)                                        -->
    <!-- ============================================================ -->
    <extension name="park_call">
      <condition field="destination_number" expression="^\*5([0-9]+)$">
        <action application="set" data="valet_hold_music=local_stream://moh"/>
        <action application="valet_park" data="valet_lot $1"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- Outbound PSTN Calls                                          -->
    <!-- ============================================================ -->
    <extension name="outbound_pstn">
      <condition field="destination_number" expression="^(0[0-9]{10})$">
        <action application="set" data="effective_caller_id_name=${caller_id_name}"/>
        <action application="set" data="effective_caller_id_number=${caller_id_number}"/>
        <action application="bridge" data="sofia/gateway/voxera_trunk/$1"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- International Calls (00 + country code)                     -->
    <!-- ============================================================ -->
    <extension name="outbound_international">
      <condition field="destination_number" expression="^(00[1-9][0-9]{6,14})$">
        <action application="set" data="effective_caller_id_name=${caller_id_name}"/>
        <action application="bridge" data="sofia/gateway/voxera_trunk/$1"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- Call Recording Toggle (*1)                                   -->
    <!-- ============================================================ -->
    <extension name="toggle_recording">
      <condition field="destination_number" expression="^\*1$">
        <action application="set" data="record_session=${uuid}"/>
        <action application="record_session" data="/var/recordings/${uuid}.wav"/>
      </condition>
    </extension>

    <!-- ============================================================ -->
    <!-- Webhook notification on call events                          -->
    <!-- ============================================================ -->
    <extension name="notify_api_on_answer" continue="true">
      <condition field="${call_direction}" expression="inbound">
        <action application="set" data="api_on_answer=curl http://api:5000/api/v1/webhooks/freeswitch"/>
      </condition>
    </extension>

  </context>

  <!-- ============================================================ -->
  <!-- Public Context (Inbound from SIP Trunk)                      -->
  <!-- ============================================================ -->
  <context name="public">
    <extension name="inbound_did">
      <condition field="destination_number" expression="^(\+?[0-9]{10,15})$">
        <action application="set" data="domain_name=${domain}"/>
        <action application="transfer" data="8000 XML default"/>
      </condition>
    </extension>
  </context>

</include>
